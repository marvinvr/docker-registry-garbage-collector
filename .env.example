REGISTRY_URL=https://registry.example.com
CRON_SCHEDULE=0 3 * * *
THRESHOLD_DAYS=30
MIN_IMAGES_KEEP=3
DRY_RUN=false
RUN_ON_START=true
RUN_ONCE=false
PAGE_SIZE=100
LOG_LEVEL=info

# Optional auth. Use either username/password or a pre-issued bearer token.
# REGISTRY_USERNAME=
# REGISTRY_PASSWORD=
# REGISTRY_TOKEN=

# Optional comma-separated repository allowlist. Empty means use /v2/_catalog.
# REPOSITORIES=my-team/app,my-team/api

# latest is always protected and does not need to be listed here.
# PROTECTED_TAGS=prod,stable

# Optional official Distribution garbage collection.
RUN_GARBAGE_COLLECT=false
# REGISTRY_CONFIG_PATH=/etc/docker/registry/config.yml
# Defaults to DRY_RUN when unset.
# GARBAGE_COLLECT_DRY_RUN=false
GARBAGE_COLLECT_DELETE_UNTAGGED=true

# Required for real non-dry-run garbage collection.
REGISTRY_READ_ONLY=false
